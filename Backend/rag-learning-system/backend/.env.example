APP_NAME=RAG Learning System
APP_ENV=development
LOG_LEVEL=INFO

MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=rag_learning
MONGO_COLLECTION_NAME=approved_knowledge

CHROMA_PATH=./chroma_db
CHROMA_COLLECTION_NAME=shopping_knowledge
TOP_K=3

EMBEDDING_MODEL=all-MiniLM-L6-v2

# Ollama should run locally outside Docker on host machine.
OLLAMA_BASE_URL=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_SECONDS=120
