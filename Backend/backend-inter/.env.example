# ─────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your values for LOCAL dev.
# For Railway, set these in the service's "Variables" tab.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── MongoDB ───────────────────────────────────────────────────
# Railway: set this to your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ecommerce?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong random string, e.g.: openssl rand -hex 32
JWT_SECRET=change-this-jwt-secret-in-production

# ── Firebase Admin SDK ────────────────────────────────────────
# REQUIRED for login to work on Railway.
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download the JSON file
# 3. Minify it with: cat serviceAccountKey.json | python -m json.tool --compact
# 4. Paste the entire single-line JSON string as the value below
# NOTE: Do NOT commit this value to git!
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"ai-ml-e-commerce-platform","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxx@ai-ml-e-commerce-platform.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ── Frontend URL (for CORS) ────────────────────────────────────
# Railway: set to your frontend Railway public URL
FRONTEND_URL=https://your-frontend.up.railway.app

# ── Cloudinary (for image uploads) ────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── AI Services ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_ENABLED=false
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Internal Service URLs (Railway) ───────────────────────────
RESTOCK_ML_API=http://restock-ml:8001
RECOMMENDATION_SERVICE_URL=http://recommendation-engine:8002
YOUTUBE_TRENDING_URL=http://youtube-trending:8003
BOOKKEEPING_API_BASE_URL=http://bookkeeping-service:4020
FACE_SERVICE_URL=http://face-service:5000
RAG_SERVICE_URL=http://weather-rag-service:8010

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_FACEBOOK_MODULE=false
FACE_RECOGNITION_ENABLED=false
FACE_SIMILARITY_THRESHOLD=0.45
RAG_CHAT_ENABLED=true
RAG_CHAT_TIMEOUT_MS=60000
