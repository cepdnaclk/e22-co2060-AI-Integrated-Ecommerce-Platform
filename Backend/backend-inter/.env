MONGO_URI=mongodb://ecommerce-mongodb:27017/ecommerce
PORT=3000
# Add your email credentials here for n8n to use if you use SMTP
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

ENABLE_FACEBOOK_MODULE=true
# You will also need these for the n8n Facebook Node credentials
FB_PAGE_ID=your_page_id_here
FB_ACCESS_TOKEN=your_long_lived_page_token
