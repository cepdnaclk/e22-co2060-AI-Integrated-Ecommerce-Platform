{
  "name": "bookkeeping-service",
  "version": "1.0.0",
  "description": "Automated event-driven bookkeeping microservice for e-commerce",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:api": "node src/server.js",
    "start:worker": "node src/worker.js",
    "dev:api": "nodemon src/server.js",
    "dev:worker": "nodemon src/worker.js",
    "test": "cross-env NODE_ENV=test USE_REDIS_MOCK=true node --test tests"
  },
  "keywords": [
    "accounting",
    "bookkeeping",
    "bullmq",
    "mongo",
    "redis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bullmq": "^5.47.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.8.1",
    "mongoose": "8.10",
    "morgan": "^1.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "ioredis-mock": "^8.9.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  }
}
