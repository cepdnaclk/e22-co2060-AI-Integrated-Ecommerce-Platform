# ============================================================================
# YouTube Trending System - Environment Configuration
# ============================================================================

# ============================================================================
# API Configuration
# ============================================================================
# Port to expose the FastAPI server (default: 8000)
API_PORT=8000

# ============================================================================
# YouTube & Google APIs
# ============================================================================
# YouTube Data API v3 Key
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Sheet ID for data storage
# Format: https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ============================================================================
# Google Cloud Credentials
# ============================================================================
# Path to service account JSON (relative to project root)
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts/
GOOGLE_CREDENTIALS_PATH=credentials.json

# ============================================================================
# Logging
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Pipeline Configuration (for scheduler)
# ============================================================================
# Cron schedule for daily pipeline execution (03:00 UTC = "0 3 * * *")
SCHEDULE=0 3 * * *
